{
  "name": "@yinxulai/eslint-plugin-peculiar",
  "version": "1.0.6",
  "description": "Peculiar ESLint plugin with custom function-related rules: definition allowance, signature linebreaks, and maximum parameter count.",
  "homepage": "https://github.com/yinxulai/eslint-plugin-peculiar#readme",
  "bugs": {
    "url": "https://github.com/yinxulai/eslint-plugin-peculiar/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yinxulai/eslint-plugin-peculiar"
  },
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "output/index.js",
  "types": "output/index.d.ts",
  "files": [
    "output"
  ],
  "keywords": [
    "eslint",
    "eslint-plugin",
    "eslintplugin",
    "function",
    "peculiar"
  ],
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf output",
    "prepublishOnly": "npm run clean && npm run build",
    "pretest": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "eslint": ">=8.40.0"
  },
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "@types/node": "^20.19.41",
    "@typescript-eslint/parser": "^8.60.1",
    "@typescript-eslint/utils": "^8.60.1",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.39.4",
    "typescript": "^5.4.5",
    "vitest": "^2.1.9"
  }
}
